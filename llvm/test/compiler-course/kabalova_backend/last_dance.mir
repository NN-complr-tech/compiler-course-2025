# RUN: llc -mtriple x86_64-unknown-linux-gnu --load=%llvmshlibdir/CounterPass_Kabalova_Valeria_FIIT1_BACKEND%shlibext \
# RUN: -run-pass=counter-pass-x86  %s -o - | FileCheck %s


# // SSE
# __m128 add1(__m128 a, __m128 b){
#   __m128 c = _mm_add_ps(a, b);
#   return c;
# }
# 
# // SSE2 
# __m128d add2(__m128d a, __m128d b){
#   __m128d c = _mm_add_pd(a, b);
#   return c;
# }
# 
# //AVX
# __m256 add3(__m256 a, __m256 b){
#   __m256 c = _mm256_add_ps(a, b);
#   return c;
# }
# 
# //AVX512
# __m512d add4(__m512d a, __m512d b){
#   __m512d c = _mm512_add_pd(a, b);
#   return c;
# }


--- |
  ; ModuleID = '/home/m1likus/code/compiler-course-2025/llvm/test/compiler-course/kabalova_backend/test.mir'
  source_filename = "/home/m1likus/code/compiler-course-2025/llvm/test/compiler-course/kabalova_backend/test.cpp"
  target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
  target triple = "x86_64-pc-linux-gnu"
  
  @counter = global i64 0, align 8
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable
  define dso_local noundef <4 x float> @_Z4add1Dv4_fS_(<4 x float> noundef %0, <4 x float> noundef %1) local_unnamed_addr #0 {
    %3 = fadd <4 x float> %0, %1
    ret <4 x float> %3
  }
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable
  define dso_local noundef <2 x double> @_Z4add2Dv2_dS_(<2 x double> noundef %0, <2 x double> noundef %1) local_unnamed_addr #0 {
    %3 = fadd <2 x double> %0, %1
    ret <2 x double> %3
  }
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable
  define dso_local noundef <8 x float> @_Z4add3Dv8_fS_(<8 x float> noundef %0, <8 x float> noundef %1) local_unnamed_addr #1 {
    %3 = fadd <8 x float> %0, %1
    ret <8 x float> %3
  }
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable
  define dso_local noundef <8 x double> @_Z4add4Dv8_dS_(<8 x double> noundef %0, <8 x double> noundef %1) local_unnamed_addr #2 {
    %3 = fadd <8 x double> %0, %1
    ret <8 x double> %3
  }
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable
  define dso_local noundef i32 @main() local_unnamed_addr #3 {
    ret i32 0
  }
  
  attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable "min-legal-vector-width"="128" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+avx2,+avx512f,+cmov,+crc32,+cx8,+evex512,+f16c,+fma,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx,+avx" "tune-cpu"="generic" }
  attributes #1 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable "min-legal-vector-width"="256" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+avx2,+avx512f,+cmov,+crc32,+cx8,+evex512,+f16c,+fma,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx,+avx" "tune-cpu"="generic" }
  attributes #2 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable "min-legal-vector-width"="512" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+avx2,+avx512f,+cmov,+crc32,+cx8,+evex512,+f16c,+fma,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx,+avx" "tune-cpu"="generic" }
  attributes #3 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) uwtable "min-legal-vector-width"="0" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+avx2,+avx512f,+cmov,+crc32,+cx8,+evex512,+f16c,+fma,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx,+avx" "tune-cpu"="generic" }
  
  !llvm.module.flags = !{!0, !1, !2, !3}
  !llvm.ident = !{!4}
  
  !0 = !{i32 1, !"wchar_size", i32 4}
  !1 = !{i32 8, !"PIC Level", i32 2}
  !2 = !{i32 7, !"PIE Level", i32 2}
  !3 = !{i32 7, !"uwtable", i32 2}
  !4 = !{!"Ubuntu clang version 18.1.3 (1ubuntu1)"}

...
