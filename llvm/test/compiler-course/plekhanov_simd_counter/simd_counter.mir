# RUN: llc -mtriple=x86_64-unknown-linux-gnu -mattr=+avx \
# RUN:   --load=%llvmshlibdir/SimdPass_Plekhanov_Daniil_FIIT2_BACKEND%shlibext \
# RUN:   -run-pass=simd-pass %s -o - | FileCheck %s

---
name: test_simd_many
tracksRegLiveness: true
stack:
  - { id: 0, size: 16, alignment: 16 }
body: |
  bb.0:
    ; CHECK: ADD64mi8
    %0:vr128 = IMPLICIT_DEF
    %1:vr128 = COPY %0
    %2:vr128 = ADDPSrr %0, %1, implicit $mxcsr
    %3:vr128 = MULPSrr %0, %1, implicit $mxcsr
    %4:vr128 = SUBPSrr %2, %3, implicit $mxcsr
    %5:vr128 = XORPSrr %2, %4
    %6:vr128 = ANDPSrr %3, %5
    %7:vr128 = ORPSrr %6, %1
    %8:vr128 = SHUFPSrri %7, %0, 1
    %9:vr128 = MOVAPSrm %stack.0, 0, $noreg, 0, $noreg
    %10:vr128 = ADDPSrr %8, %9, implicit $mxcsr
    %11:vr128 = MULPSrr %10, %7, implicit $mxcsr
    RET 0
...
