# Тест оптимизации умножения-вычитания: (a * b) - c → VFMSUB213SS
# CHECK-LABEL: name: test_multiplication_subtraction_fusion
# CHECK: bb.0.entry:
# CHECK-NOT: VMULSSrr
# CHECK-NOT: VSUBSSrr
# CHECK: %[[RESULT:[a-z0-9]+]]:fr32 = VFMSUB213SSr %0, %1, %2, implicit $mxcsr
# CHECK: $xmm0 = COPY %[[RESULT]]
# CHECK: RET64 implicit $xmm0

---
name:            test_multiplication_subtraction_fusion
alignment:       16
tracksRegLiveness: true
registers:
  - { id: 0, class: fr32 }
  - { id: 1, class: fr32 }
  - { id: 2, class: fr32 }
  - { id: 3, class: fr32 }
  - { id: 4, class: fr32 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2

    %2:fr32 = COPY $xmm2
    %1:fr32 = COPY $xmm1
    %0:fr32 = COPY $xmm0
    %3:fr32 = nofpexcept VMULSSrr %0, %1, implicit $mxcsr
    %4:fr32 = nofpexcept VSUBSSrr killed %3, %2, implicit $mxcsr
