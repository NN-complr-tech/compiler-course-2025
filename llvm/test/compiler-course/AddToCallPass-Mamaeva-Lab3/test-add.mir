# RUN: llc -mtriple=x86_64-unknown-linux-gnu \
# RUN:     --load=%llvmshlibdir/FMADecomposePass_Mamaeva_Olga_FIIT3_BACKEND%shlibext \
# RUN:     -run-pass=fma-decompose %s -o - | FileCheck %s

--- |
  define float @test(float %a, float %b, float %c) {
    %res = call float @llvm.fma.f32(float %a, float %b, float %c)
    ret float %res
  }
...
---
name:            test
body:             |
  bb.0 (%ir-block.0):
    liveins: $xmm0, $xmm1, $xmm2
    
    ; CHECK:      %3:fr32 = MULSSrr %0, %1, implicit $mxcsr
    ; CHECK-NEXT: %2:fr32 = ADDSSrr %2, %3, implicit $mxcsr
    ; CHECK-NEXT: $xmm0 = COPY %2
    ; CHECK-NEXT: RET 0, $xmm0
    
    %0:fr32 = COPY $xmm0
    %1:fr32 = COPY $xmm1
    %2:fr32 = COPY $xmm2
    %2:fr32 = VFMADD213SSr %0, %1, %2, implicit $mxcsr
    $xmm0 = COPY %2
    RET 0, $xmm0
