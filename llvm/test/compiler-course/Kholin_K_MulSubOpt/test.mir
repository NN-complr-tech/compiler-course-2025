# RUN: llc -mtriple=x86_64-unknown-linux-gnu -mattr=+fma \
# RUN:     --load %llvmshlibdir/MulSubPass_KholinKirill_FIIT3_BACKEND%shlibext \
# RUN:     -run-pass=mul-sub-opt %s -o - | FileCheck %s

--- |
  ; ModuleID = 'test.ll'
  source_filename = "Kholin_K_MulSub_test.cpp"
  target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
  target triple = "x86_64-pc-linux-gnu"
  
  module asm ".globl _ZSt21ios_base_library_initv"
  
  %"class.std::basic_ostream" = type { ptr, %"class.std::basic_ios" }
  %"class.std::basic_ios" = type { %"class.std::ios_base", ptr, i8, i8, ptr, ptr, ptr, ptr }
  %"class.std::ios_base" = type { ptr, i64, i64, i32, i32, i32, ptr, %"struct.std::ios_base::_Words", [8 x %"struct.std::ios_base::_Words"], i32, ptr, %"class.std::locale" }
  %"struct.std::ios_base::_Words" = type { ptr, i64 }
  %"class.std::locale" = type { ptr }
  
  @_ZSt4cout = external global %"class.std::basic_ostream", align 8
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef float @_Z20classic_mul_sub_testfff(float noundef %0, float noundef %1, float noundef %2) #0 {
    %4 = fmul float %0, %1
    %5 = fsub float %2, %4
    ret float %5
  }
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef float @_Z28reverse_classic_mul_sub_testfff(float noundef %0, float noundef %1, float noundef %2) #0 {
    %4 = fmul float %0, %1
    %5 = fneg float %4
    %6 = fadd float %5, %2
    ret float %6
  }
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef float @_Z19return_mul_sub_testfff(float noundef %0, float noundef %1, float noundef %2) #0 {
    %4 = fmul float %1, %0
    %5 = fsub float %2, %4
    ret float %5
  }
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef float @_Z21multiple_mul_sub_testfff(float noundef %0, float noundef %1, float noundef %2) #0 {
    %4 = fmul float %0, %1
    %5 = fsub float %2, %4
    %6 = fmul float %1, %2
    %7 = fsub float %0, %6
    %8 = fadd float %5, %7
    ret float %8
  }
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef double @_Z27classic_double_mul_sub_testddd(double noundef %0, double noundef %1, double noundef %2) #0 {
    %4 = fmul double %0, %1
    %5 = fsub double %2, %4
    ret double %5
  }
  
  ; Function Attrs: mustprogress noinline nounwind uwtable
  define dso_local noundef float @_Z19nested_mul_sub_testffff(float noundef %0, float noundef %1, float noundef %2, float noundef %3) #0 {
    %5 = fmul float %0, %1
    %6 = fsub float %2, %5
    %7 = fmul float %6, %3
    ret float %7
  }
  
  attributes #0 = { mustprogress noinline nounwind uwtable "frame-pointer"="all" "min-legal-vector-width"="0" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+cmov,+cx8,+fxsr,+mmx,+sse,+sse2,+x87" "tune-cpu"="generic" }
  attributes #1 = { mustprogress noinline norecurse uwtable "frame-pointer"="all" "min-legal-vector-width"="0" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+cmov,+cx8,+fxsr,+mmx,+sse,+sse2,+x87" "tune-cpu"="generic" }
  attributes #2 = { "frame-pointer"="all" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+cmov,+cx8,+fxsr,+mmx,+sse,+sse2,+x87" "tune-cpu"="generic" }
  
  !llvm.module.flags = !{!0, !1, !2, !3, !4}
  !llvm.ident = !{!5}
  
  !0 = !{i32 1, !"wchar_size", i32 4}
  !1 = !{i32 8, !"PIC Level", i32 2}
  !2 = !{i32 7, !"PIE Level", i32 2}
  !3 = !{i32 7, !"uwtable", i32 2}
  !4 = !{i32 7, !"frame-pointer", i32 2}
  !5 = !{!"Ubuntu clang version 18.1.3 (1ubuntu1)"}

# CHECK-LABEL: name: _Z20classic_mul_sub_testfff
# CHECK: %8:fr32 = VFNMADD213SSr %1, %3, %5, implicit $mxcsr
# CHECK-NEXT: $xmm0 = COPY %8
# CHECK-NEXT: RET64 implicit $xmm0

...
