    %6:fr32 = COPY $xmm3
    %4:fr32 = COPY $xmm2
    %2:fr32 = COPY $xmm1
    %0:fr32 = COPY $xmm0
    %1:fr32 = COPY killed %0
    %3:fr32 = COPY killed %2
    %5:fr32 = COPY killed %4
    %7:fr32 = COPY killed %6
    %13:fr32 = MULSSrr %1, %3, implicit $mxcsr
    %12:fr32 = SUBSSrr %5, %13, implicit $mxcsr
    %10:fr32 = MULSSrr %12, %7, implicit $mxcsr
    $xmm0 = COPY %10
    RET64 implicit $xmm0
	
