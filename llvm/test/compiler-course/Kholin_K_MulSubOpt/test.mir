    %4:fr32 = nofpexcept MULSSrr %0, %1, implicit $mxcsr
    %5:fr32 = nofpexcept SUBSSrr %2, killed %4, implicit $mxcsr
    %6:fr32 = nofpexcept MULSSrr %5, %3, implicit $mxcsr
    $xmm0 = COPY %6
    RET 0, $xmm0

