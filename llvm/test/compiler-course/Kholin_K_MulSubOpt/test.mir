debugValueSubstitutions: []
constants:       []
machineFunctionInfo:
  amxProgModel:    None
body:             |
  bb.0 (%ir-block.3):
    liveins: $xmm0, $xmm1, $xmm2
  
    %4:fr32 = COPY $xmm2
    %2:fr32 = COPY $xmm1
    %0:fr32 = COPY $xmm0
    %1:fr32 = COPY killed %0
    %3:fr32 = COPY killed %2
    %5:fr32 = COPY killed %4
    %9:fr32 = MULSSrr %1, %3, implicit $mxcsr
    %8:fr32 = SUBSSrr %5, %9, implicit $mxcsr
    $xmm0 = COPY %8
    RET64 implicit $xmm0
	
